<Window x:Class="BookRescue.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="BookRescue"
        Icon="Assets/bookrescue-icon.ico"
        Height="860"
        Width="1480"
        MinHeight="720"
        MinWidth="1180"
        Background="#F8FAFD">
    <Window.Resources>
        <LinearGradientBrush x:Key="TopAccentBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#E8F0FE" Offset="0" />
            <GradientStop Color="#E6F4EA" Offset="0.56" />
            <GradientStop Color="#FEF7E0" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DADCE0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14"
                                      Direction="270"
                                      Opacity="0.10"
                                      ShadowDepth="2"
                                      Color="#202124" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#202124" />
        </Style>

        <Style x:Key="SubtleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5F6368" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="GoogleBlueButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1A73E8" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1A73E8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="MinHeight" Value="32" />
        </Style>

        <Style x:Key="GoogleGreenButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#34A853" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#34A853" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="MinHeight" Value="32" />
        </Style>

        <Style x:Key="FeatureChip" TargetType="Border">
            <Setter Property="Background" Value="#F1F3F4" />
            <Setter Property="BorderBrush" Value="#E8EAED" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="13" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="White"
                BorderBrush="#DADCE0"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Menu Grid.Row="0"
                      Background="White"
                      Foreground="#202124"
                      Padding="8,2">
                    <MenuItem Header="_Archivo">
                        <MenuItem Header="Subir libro(s)" Command="{Binding AddBooksCommand}" />
                        <MenuItem Header="Elegir carpeta destino" Command="{Binding BrowseOutputFolderCommand}" />
                    </MenuItem>
                    <MenuItem Header="_Idioma">
                        <MenuItem Header="Idioma de salida">
                            <MenuItem Header="Español" Command="{Binding SetOutputLanguageCommand}" CommandParameter="es" />
                            <MenuItem Header="Inglés" Command="{Binding SetOutputLanguageCommand}" CommandParameter="en" />
                        </MenuItem>
                    </MenuItem>
                    <MenuItem Header="_Ayuda">
                        <MenuItem Header="Actualizar" Command="{Binding CheckForUpdatesCommand}" />
                        <MenuItem Header="Créditos" Command="{Binding ShowCreditsCommand}" />
                    </MenuItem>
                </Menu>

                <Grid Grid.Row="1" Margin="18,8,18,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Width="34"
                               Height="34"
                               Margin="0,0,10,0"
                               Source="Assets/bookrescue-icon.png" />
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="23" FontWeight="SemiBold" Foreground="#4285F4" Text="Book" />
                                <TextBlock FontSize="23" FontWeight="SemiBold" Foreground="#34A853" Text="Rescue" />
                            </StackPanel>
                            <TextBlock Style="{StaticResource SubtleText}"
                                       Text="Reconstrucción local de libros escaneados" />
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Height="40"
                            Margin="28,0"
                            Background="{StaticResource TopAccentBrush}"
                            CornerRadius="20"
                            BorderBrush="#E8EAED"
                            BorderThickness="1">
                        <Grid Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="#5F6368"
                                       FontSize="16"
                                       Text="Listo para rescatar" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       Foreground="#5F6368"
                                       Text="{Binding StatusMessage}" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Margin="0,0,12,0"
                                Padding="9,5"
                                Background="#F1F3F4"
                                BorderBrush="#DADCE0"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="10"
                                         Height="10"
                                         Margin="0,0,7,0"
                                         VerticalAlignment="Center"
                                         Fill="{Binding AiIndicatorBrush}" />
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="#3C4043"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Text="{Binding AiIndicatorText}" />
                            </StackPanel>
                        </Border>
                        <Button Content="Subir"
                                Command="{Binding AddBooksCommand}"
                                Style="{StaticResource GoogleGreenButton}" />
                        <Button Content="Actualizar"
                                Command="{Binding CheckForUpdatesCommand}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="White"
                BorderBrush="#DADCE0"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center"
                           Foreground="#3C4043"
                           Text="{Binding StatusMessage}" />
                <ProgressBar Grid.Column="1"
                             Height="8"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding GlobalProgress}" />
            </Grid>
        </Border>

        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource Panel}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Style="{StaticResource FeatureChip}">
                            <TextBlock Foreground="#3C4043" Text="Texto editable" />
                        </Border>
                        <Border Style="{StaticResource FeatureChip}">
                            <TextBlock Foreground="#3C4043" Text="Figuras rescatadas" />
                        </Border>
                        <Border Style="{StaticResource FeatureChip}">
                            <TextBlock Foreground="#3C4043" Text="Tablas reconstruidas" />
                        </Border>
                        <Border Style="{StaticResource FeatureChip}">
                            <TextBlock Foreground="#3C4043" Text="Trabajo local" />
                        </Border>
                    </StackPanel>

                    <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="1.7*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Destino" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1"
                                    Content="Cambiar"
                                    Command="{Binding BrowseOutputFolderCommand}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Idioma de salida" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding OutputLanguageOptions}"
                                      SelectedItem="{Binding OutputLanguage}"
                                      MinHeight="30" />
                            <CheckBox Grid.Column="1"
                                      Margin="12,0,0,0"
                                      VerticalAlignment="Center"
                                      Content="Traducir automáticamente"
                                      IsChecked="{Binding EnableTranslation}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Perfil de salida" />
                        <UniformGrid Columns="4" Margin="0,10,0,0">
                            <CheckBox Content="PDF" IsChecked="{Binding OutputPdf}" />
                            <CheckBox Content="Word" IsChecked="{Binding OutputWord}" />
                            <CheckBox Content="ePub" IsChecked="{Binding OutputEpub}" />
                            <CheckBox Content="CSV" IsChecked="{Binding OutputCsv}" />
                        </UniformGrid>
                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource SectionTitle}"
                                   Text="Modo de reconstrucción" />
                        <ComboBox Margin="0,6,0,0"
                                  MinHeight="30"
                                  ItemsSource="{Binding ReconstructionModeOptions}"
                                  SelectedItem="{Binding SelectedReconstructionMode}" />
                        <TextBlock Margin="0,5,0,0"
                                   Style="{StaticResource SubtleText}"
                                   Text="{Binding ReconstructionModeHelp}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#B06000"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Text="{Binding ReconstructionModeWarning}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="1.25*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Panel}" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SectionTitle}" Text="Cola de conversión" />
                            <TextBlock Grid.Column="1"
                                       Style="{StaticResource SubtleText}"
                                       VerticalAlignment="Center"
                                       Text="{Binding PendingBooks.Count, StringFormat={}{0} archivo(s)}" />
                        </Grid>

                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding PendingBooks}"
                                  SelectedItem="{Binding SelectedPendingBook}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  BorderBrush="#E8EAED"
                                  BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Archivo" Binding="{Binding FileName}" Width="2.2*" />
                                <DataGridTextColumn Header="Estado" Binding="{Binding Status}" Width="1*" />
                                <DataGridTextColumn Header="Va" Binding="{Binding ElapsedText}" Width="0.75*" />
                                <DataGridTextColumn Header="Estimado" Binding="{Binding EstimatedText}" Width="1.05*" />
                                <DataGridTemplateColumn Header="Progreso" Width="1.2*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ProgressBar Minimum="0"
                                                         Maximum="100"
                                                         Height="8"
                                                         Value="{Binding Progress}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Detalle" Binding="{Binding Details}" Width="1.5*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Quitar" Command="{Binding RemoveSelectedBookCommand}" />
                            <Button Content="Limpiar" Command="{Binding ClearCompletedCommand}" />
                            <Button Content="Cancelar" Command="{Binding CancelRescueCommand}" />
                            <Button Content="Rescatar"
                                    Command="{Binding StartRescueCommand}"
                                    Style="{StaticResource GoogleBlueButton}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Panel}" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SectionTitle}" Text="Biblioteca" />
                            <Button Grid.Column="1"
                                    Content="Limpiar"
                                    Command="{Binding ClearSessionLibraryCommand}" />
                        </Grid>

                        <ListView Grid.Row="2"
                                  ItemsSource="{Binding LibraryItems}"
                                  SelectedItem="{Binding SelectedLibraryItem}"
                                  BorderBrush="#E8EAED"
                                  BorderThickness="1">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Libro" Width="270" DisplayMemberBinding="{Binding SourceFileName}" />
                                    <GridViewColumn Header="Fecha" Width="132" DisplayMemberBinding="{Binding CreatedAtLocal}" />
                                    <GridViewColumn Header="Formatos" Width="140" DisplayMemberBinding="{Binding AvailableOutputs}" />
                                    <GridViewColumn Header="Carpeta" Width="390" DisplayMemberBinding="{Binding OutputFolder}" />
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Abrir PDF" Command="{Binding OpenSelectedPdfCommand}" />
                            <Button Content="Abrir Word" Command="{Binding OpenSelectedDocxCommand}" />
                            <Button Content="Abrir ePub" Command="{Binding OpenSelectedEpubCommand}" />
                            <Button Content="Abrir CSV" Command="{Binding OpenSelectedCsvCommand}" />
                            <Button Content="Abrir carpeta" Command="{Binding OpenSelectedOutputFolderCommand}" />
                        </StackPanel>

                        <TextBlock Grid.Row="6"
                                   HorizontalAlignment="Right"
                                   Style="{StaticResource SubtleText}"
                                   Text="{Binding CreditsText}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
